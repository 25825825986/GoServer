# 服务器配置
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10
SERVER_WRITE_TIMEOUT=10
SERVER_MAX_WORKERS=100

# MySQL配置（主存储）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=goserver
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_MAX_OPEN_CONNS=25
MYSQL_MAX_IDLE_CONNS=10

# Redis配置（缓存层）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DB=0
REDIS_MAX_RETRY=3
REDIS_POOL_SIZE=10

# 应用配置
APP_NAME=LogProcessor
APP_VERSION=2.0.0
ENVIRONMENT=development
BATCH_SIZE=100
WORKERS=10
QUEUE_SIZE=1000
